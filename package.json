{
  "name": "serverless-imagebed-page",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "metadata": "node scripts/generate-metadata.mjs",
    "thumbs": "node scripts/generate-thumbs.mjs",
    "prebuild": "mkdir -p public/images && cp -r images/. public/images/ && npm run metadata && npm run thumbs",
    "dev": "mkdir -p public/images && cp -r images/. public/images/ && npm run metadata && next dev",
    "build": "next build",
    "build:cf": "mkdir -p public/images && cp -r images/. public/images/ && npm run metadata && npm run thumbs && npx @opennextjs/cloudflare build",
    "preview:cf": "npx wrangler pages dev .worker-static --compatibility-flag=nodejs_compat",
    "start": "next start",
    "test": "vitest run",
    "lint": "eslint"
  },
  "dependencies": {
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sharp": "^0.35.2"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.20.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
