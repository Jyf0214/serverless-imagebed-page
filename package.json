{
  "name": "serverless-imagebed-page",
  "version": "1.2.1",
  "private": true,
  "scripts": {
    "sync": "node scripts/sync-webdav.mjs",
    "metadata": "node scripts/generate-metadata.mjs",
    "thumbs": "node scripts/generate-thumbs.mjs",
    "prebuild": "npm run sync && mkdir -p public/images && cp -r images/. public/images/ && npm run metadata && npm run thumbs",
    "dev": "npm run sync && mkdir -p public/images && cp -r images/. public/images/ && npm run metadata && next dev",
    "build": "next build",
    "start": "next start",
    "test": "vitest run",
    "lint": "eslint --max-warnings 0"
  },
  "dependencies": {
    "@ant-design/icons": "^6.3.2",
    "antd": "^6.5.0",
    "lucide-react": "^1.22.0",
    "motion": "^12.42.2",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sharp": "^0.35.2",
    "webdav": "^5.10.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.16",
    "tailwindcss": "^4.3.2",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
